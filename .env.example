# Copier vers .env.local (dev) ou configurer dans Vercel / hébergeur (prod).
# Ne jamais committer de fichiers .env contenant de vraies valeurs.

# Supabase (obligatoire pour l’app Next)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-jwt
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres (pooler Supabase / Prisma si utilisé)
POSTGRES_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_HOST=db.xxx.supabase.co
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password

# URL publique de l’app (recommandé en prod pour les liens / QR code « rejoindre »)
# NEXT_PUBLIC_APP_URL=https://votre-domaine.vercel.app

# Redirections auth (optionnel)
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/dashboard

# IA / gateway (serveur uniquement — ne pas préfixer NEXT_PUBLIC_ pour les secrets)
ANTHROPIC_AUTH_TOKEN=
AI_GATEWAY_API_KEY=

# Vercel
VERCEL_WEB_ANALYTICS_ID=
# VERCEL_OIDC_TOKEN est injecté par Vercel en CI ; ne pas le copier manuellement en prod sauf besoin précis

# SuperPrompt (génération de QCM) — au moins une clé côté serveur
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Optionnel : analytics, monitoring, paiements
NEXT_PUBLIC_ANALYTICS_ID=
SENTRY_DSN=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
